# ── Self-hosted AI — dummy key for the OpenAI-compatible plugins (local servers ignore it) ──
OPENAI_API_KEY=not-needed

# ── Booking database ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/restaurant_db

# ── Self-hosted model endpoints (defaults; docker-compose overrides with service names) ──
STT_BASE_URL=http://localhost:8000/v1
LLM_BASE_URL=http://localhost:11434/v1
TTS_BASE_URL=http://localhost:8880/v1
STT_MODEL=Systran/faster-distil-whisper-small.en
LLM_MODEL=qwen2.5:3b
TTS_VOICE=af_bella

# ── LiveKit ──
# Self-hosted dev defaults shown. For a REAL phone number, point these at your
# LiveKit Cloud project and set AGENT_NAME to the name your SIP dispatch rule targets.
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
AGENT_NAME=

# ── Optional: restaurant ambience under the agent's voice (real calls only) ──
BACKGROUND_AUDIO=

# ── Optional: Twilio WhatsApp booking confirmation (sandbox) ──
# Recipient must have joined the Twilio WhatsApp sandbox first.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
BOOKING_NOTIFY_WHATSAPP=

# ── Optional: email a PDF call summary to the manager on booking (bonus B2) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
MANAGER_EMAIL=
